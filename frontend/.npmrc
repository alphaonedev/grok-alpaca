# Supply-chain hardening — see ../SECURITY.md.

# Pin the registry so a hijacked npm config can't redirect to a malicious mirror.
registry = https://registry.npmjs.org/

# Reproducible installs. CI and `make install` use `npm ci` so the lockfile is
# the only resolution source. SRI integrity in package-lock.json is verified
# on every install.
package-lock = true
save-exact = true

# Surface advisories during install. `npm audit --audit-level=high` blocks CI.
audit = true
audit-level = high

# Block ALL lifecycle scripts at install time. After `npm ci`, run
# `npx allow-scripts` to execute ONLY the explicitly allowlisted ones from
# package.json `lavamoat.allowScripts`.
#
# This is the strongest available defense against the May-2026 TanStack and
# March-2026 Axios pattern, both of which used install-time code execution.
# A compromised dependency cannot run code on `npm ci` here.
ignore-scripts = true

# Engines declared in package.json. We do NOT set engine-strict=true at the
# global level because some dependencies (notably @lavamoat/allow-scripts)
# declare narrow engine ranges that lag Node releases. CI matrix runs on the
# supported LTS versions (20, 22) and would catch real drift.

# Less surface for typo-squat at lookup time.
fund = false
update-notifier = false
