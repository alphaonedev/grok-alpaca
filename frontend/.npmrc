# Supply-chain hardening — see SECURITY.md.

# Reproducible installs. CI and `make install` use `npm ci` so the lockfile is
# the only resolution source.
package-lock = true
save-exact = true

# Surface advisories during install. `npm audit --audit-level=high` blocks CI.
audit = true
audit-level = high

# Lifecycle-script discipline:
# npm does not support a native per-package allow-script list (pnpm/yarn do).
# Today's packages that run install scripts: esbuild, fsevents, es5-ext.
# To opt out entirely, set `ignore-scripts=true` and run
# `npm rebuild esbuild fsevents` explicitly after install — but the platform
# binary downloads will fail without those scripts. We accept this risk and
# enforce other layers (lockfile pinning, audit signatures in CI, pinned
# version cadence).
ignore-scripts = false

# Use `npm audit signatures` in CI to verify provenance attestations
# (npm >= 9.5). The May-2026 TanStack incident shipped valid signatures via
# OIDC trusted publishing, so this is not sufficient on its own — it catches
# the lower-grade attacks like axios March 2026.
