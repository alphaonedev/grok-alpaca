    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "react-plotly.js": "^2.6.0",
    "rehype-highlight": "^7.0.1",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.0",
