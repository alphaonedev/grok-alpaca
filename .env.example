# xAI Grok
# Get a key at https://console.x.ai/
XAI_API_KEY=

# Alpaca Markets (paper account is fine — this project is read-only)
# Get keys at https://app.alpaca.markets/paper/dashboard/overview
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
# Data feed: "iex" (free) or "sip" (paid). Defaults to iex.
ALPACA_DATA_FEED=iex

# Server (localhost-only; the app refuses any non-loopback bind)
HOST=127.0.0.1
PORT=8000

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=console      # console | json

# Grok model
GROK_MODEL=grok-4-0709
GROK_TEMPERATURE=0.3
GROK_MAX_TOOL_ROUNDS=8

# Data storage (reports, watchlists, cache)
DATA_DIR=~/.grok-alpaca
